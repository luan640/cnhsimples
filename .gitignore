pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*

# Environment and secrets
.env
.env.*
!.env.example
!.env.*.example
!.env.sample
!.env.*.sample

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.*

# Package manager caches
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
